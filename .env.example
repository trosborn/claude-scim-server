# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/scim_server

# Bearer token Okta will use to authenticate to this server
# Generate a strong random value: openssl rand -hex 32
SCIM_AUTH_TOKEN=changeme

# Port (Render sets this automatically)
PORT=3000

# Node environment
NODE_ENV=development

# Test hook: override the `active` field in POST /Users 201 responses.
# Set to "true" (Test A) or "false" (Test B) to control what Okta sees back.
# Unset (default) = echo whatever active value Okta sent.
# FORCE_POST_ACTIVE=true
