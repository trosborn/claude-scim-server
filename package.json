{
  "name": "claude-scim-server",
  "version": "1.0.0",
  "description": "SCIM 2.0 server for Okta provisioning inspection",
  "main": "src/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "migrate": "node src/db/migrate.js",
    "test": "jest --forceExit --runInBand",
    "test:coverage": "jest --forceExit --runInBand --coverage"
  },
  "dependencies": {
    "express": "^4.19.2",
    "pg": "^8.12.0",
    "uuid": "^10.0.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "globalSetup": "./tests/globalSetup.js",
    "globalTeardown": "./tests/globalTeardown.js",
"testTimeout": 15000
  }
}
